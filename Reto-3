<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <title>Reto 3 — Mirar para activar</title>
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
  </head>
  <body>

    <!--
      a-scene  →  el contenedor de todo el mundo 3D
                  A-Frame añade automáticamente el botón "Enter VR"
    -->
    <a-scene>

      <!--
        CÁMARA CON CURSOR DE MIRADA
        ────────────────────────────
        a-camera  →  representa los ojos del usuario en la escena
                     por defecto ya existe una cámara, pero la declaramos
                     explícitamente para poder añadirle el cursor dentro

        a-cursor  →  el punto de mira que el usuario lleva siempre centrado
                     funciona como un ratón, pero controlado con la cabeza

          fuse="true"
            activa el modo de mirada (gaze)
            sin esto el cursor solo funciona con clic de ratón o botón

          fuse-timeout="1500"
            milisegundos que el usuario tiene que mirar un objeto
            para que se dispare el evento click automáticamente
            1500 = 1.5 segundos (puedes ajustarlo a tu gusto)

          color="#ffffff"
            color del cursor visible en la escena

          position="0 0 -1"
            coloca el cursor justo delante de la cámara
            el -1 en Z lo pone a 1 metro de distancia de los ojos
      -->
      <a-camera>
        <a-cursor
          fuse="true"
          fuse-timeout="1500"
          color="#ffffff"
          position="0 0 -1">
        </a-cursor>
      </a-camera>

      <!--
        CAJA — se activa al mirarla
        ────────────────────────────
        animation__hover
          nombre compuesto: animation__ + nombre que tú eliges (hover)
          puedes poner varios animation__ en el mismo objeto dándoles nombres distintos

          property: scale       →  qué propiedad se anima (el tamaño)
          to: 1.3 1.3 1.3       →  crece un 30% al ser mirada
          dur: 200              →  0.2 segundos, muy rápido para dar respuesta inmediata
          startEvents: mouseenter → se activa cuando el cursor entra en el objeto

        animation__restore
          property: scale       →  misma propiedad
          to: 1 1 1             →  vuelve al tamaño original
          dur: 200              →  igual de rápido
          startEvents: mouseleave → se activa cuando el cursor sale del objeto

        event-set__click
          cambia una propiedad del objeto cuando se dispara el click
          _event: click         →  qué evento escucha
          color: #4CC3D9        →  qué propiedad cambia y a qué valor
                                   aquí cambia el color al activarse
      -->
      <a-box
        position="-2 1.5 -4"
        color="#E24B4A"
        animation__hover="
          property: scale;
          to: 1.3 1.3 1.3;
          dur: 200;
          startEvents: mouseenter"
        animation__restore="
          property: scale;
          to: 1 1 1;
          dur: 200;
          startEvents: mouseleave"
        event-set__click="
          _event: click;
          color: #4CC3D9">
      </a-box>

      <!--
        ESFERA — mismo comportamiento, distinto color de activación
        ─────────────────────────────────────────────────────────────
        el patrón es exactamente el mismo para todos los objetos interactivos:
          1. animation__hover   →  crece al mirar
          2. animation__restore →  vuelve al salir
          3. event-set__click   →  cambia color al activar
      -->
      <a-sphere
        position="0 1.5 -4"
        radius="0.6"
        color="#EF9F27"
        animation__hover="
          property: scale;
          to: 1.3 1.3 1.3;
          dur: 200;
          startEvents: mouseenter"
        animation__restore="
          property: scale;
          to: 1 1 1;
          dur: 200;
          startEvents: mouseleave"
        event-set__click="
          _event: click;
          color: #1D9E75">
      </a-sphere>

      <!--
        CILINDRO — mismo patrón
        ────────────────────────
        cada objeto tiene su propio color de activación
        para que se vea claramente cuál has mirado
      -->
      <a-cylinder
        position="2 1 -4"
        radius="0.4"
        height="2"
        color="#4CC3D9"
        animation__hover="
          property: scale;
          to: 1.3 1.3 1.3;
          dur: 200;
          startEvents: mouseenter"
        animation__restore="
          property: scale;
          to: 1 1 1;
          dur: 200;
          startEvents: mouseleave"
        event-set__click="
          _event: click;
          color: #E24B4A">
      </a-cylinder>

      <!--
        SUELO — plano horizontal estático
        ────────────────────────────────────
        rotation="-90 0 0"  →  tumbado horizontalmente
      -->
      <a-plane
        position="0 0 0"
        rotation="-90 0 0"
        width="20"
        height="20"
        color="#3a3a4a">
      </a-plane>

      <!--
        CIELO — fondo de la escena
        ───────────────────────────
        color  →  cambia este valor para probar distintos ambientes
      -->
      <a-sky color="#1a1a2e"></a-sky>

    </a-scene>

  </body>
</html>
