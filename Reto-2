<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <title>Reto 2 — Animaciones</title>
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
  </head>
  <body>

    <!--
      a-scene  →  el contenedor de todo el mundo 3D
                  A-Frame añade automáticamente el botón "Enter VR"
    -->
    <a-scene>

      <!--
        CAJA — animación de rotación continua
        ──────────────────────────────────────
        animation="..."
          property: rotation   →  qué propiedad se anima (rotación)
          to: 0 360 0          →  valor final: gira 360° en el eje Y (vertical)
                                  es una vuelta completa, como una peonza
          dur: 3000            →  duración en milisegundos (3000 = 3 segundos por vuelta)
          loop: true           →  se repite indefinidamente
      -->
      <a-box
        position="-2 1.5 -4"
        color="#E24B4A"
        animation="
          property: rotation;
          to: 0 360 0;
          dur: 3000;
          loop: true">
      </a-box>

      <!--
        ESFERA — animación de flotación (sube y baja)
        ──────────────────────────────────────────────
        animation="..."
          property: position    →  qué propiedad se anima (posición)
          from: 0 1.5 -4        →  posición inicial (abajo)
          to: 0 2.5 -4          →  posición final (arriba, 1 metro más alto)
          dur: 1500             →  1.5 segundos de subida
          loop: true            →  se repite
          dir: alternate        →  va y vuelve (sube, baja, sube, baja...)
                                   sin esto solo subiría y aparecería abajo de golpe
          easing: easeInOutSine →  el movimiento acelera y desacelera suavemente
                                   sin esto el movimiento sería brusco y mecánico
      -->
      <a-sphere
        position="0 1.5 -4"
        radius="0.6"
        color="#EF9F27"
        animation="
          property: position;
          from: 0 1.5 -4;
          to: 0 2.5 -4;
          dur: 1500;
          loop: true;
          dir: alternate;
          easing: easeInOutSine">
      </a-sphere>

      <!--
        CILINDRO — animación de pulso (crece y encoge)
        ────────────────────────────────────────────────
        animation="..."
          property: scale       →  qué propiedad se anima (escala/tamaño)
          from: 1 1 1           →  tamaño original (100%)
          to: 1.3 1.3 1.3       →  tamaño final (130%, un 30% más grande)
          dur: 800              →  0.8 segundos, más rápido que las otras
                                   para que se sienta como un latido
          loop: true            →  se repite
          dir: alternate        →  crece y encoge, crece y encoge...
      -->
      <a-cylinder
        position="2 1.5 -4"
        radius="0.4"
        height="1.5"
        color="#4CC3D9"
        animation="
          property: scale;
          from: 1 1 1;
          to: 1.3 1.3 1.3;
          dur: 800;
          loop: true;
          dir: alternate">
      </a-cylinder>

      <!--
        SUELO — plano horizontal estático
        ────────────────────────────────────
        rotation="-90 0 0"  →  tumbado horizontalmente
                               (por defecto los planos son verticales)
      -->
      <a-plane
        position="0 0 0"
        rotation="-90 0 0"
        width="20"
        height="20"
        color="#3a3a4a">
      </a-plane>

      <!--
        CIELO — esfera gigante que rodea toda la escena
        ─────────────────────────────────────────────────
        color  →  cambia este valor para probar distintos ambientes
      -->
      <a-sky color="#1a1a2e"></a-sky>

    </a-scene>

  </body>
</html>
