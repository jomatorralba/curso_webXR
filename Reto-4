<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8">
    <title>Reto 4 — Controladores</title>
    <script src="https://aframe.io/releases/1.5.0/aframe.min.js"></script>
  </head>
  <body>

    <a-scene>

      <!--
        MANO DERECHA — láser desde el dedo índice apuntando hacia adelante
        ────────────────────────────────────────────────────────────────────
        El raycaster ya NO va en la mano directamente.
        Va en un elemento hijo posicionado en la punta del índice.

        Así el rayo hereda la posición Y la rotación del dedo,
        no de la palma — y apunta en la dirección correcta.

        Si el rayo no sale perfectamente del índice, ajusta:
          position →  mueve el origen del rayo
          rotation →  cambia la dirección hacia la que apunta
      -->
      <a-entity
        id="mano-derecha"
        hand-controls="hand: right">

        <!--
          Origen del láser — punta del dedo índice
          ──────────────────────────────────────────
          position="0.02 0.04 -0.08"
            x =  0.02  →  ligeramente hacia el dedo índice (derecha)
            y =  0.04  →  un poco arriba (altura del dedo)
            z = -0.08  →  hacia adelante (dirección del dedo)

          rotation="-80 0 0"
            inclina el rayo hacia adelante para que apunte
            en la misma dirección que señala el índice
            ajusta este valor si el rayo apunta muy arriba o muy abajo

          raycaster
            showLine: true       →  hace visible el rayo
            far: 10              →  longitud en metros
            objects: a-box, a-sphere, a-cylinder  →  qué detecta
            lineColor: white     →  color del rayo
            lineOpacity: 0.75    →  transparencia del rayo
        -->
        <a-entity
          position="0.0 0.0 0.0"
          rotation="-80 0 0"
          raycaster="
            showLine: true;
            far: 10;
            objects: a-box, a-sphere, a-cylinder;
            lineColor: white;
            lineOpacity: 0.75">
        </a-entity>

      </a-entity>

      <!-- Mano izquierda: solo visual -->
      <a-entity
        id="mano-izquierda"
        hand-controls="hand: left">
      </a-entity>

      <!-- Caja -->
      <a-box
        position="-2 1.5 -4"
        color="#E24B4A"
        animation__hover="
          property: scale;
          to: 1.3 1.3 1.3;
          dur: 150;
          startEvents: mouseenter"
        animation__restore="
          property: scale;
          to: 1 1 1;
          dur: 150;
          startEvents: mouseleave"
        event-set__click="
          _event: click;
          color: #4CC3D9">
      </a-box>

      <!-- Esfera -->
      <a-sphere
        position="0 1.5 -4"
        radius="0.6"
        color="#EF9F27"
        animation__hover="
          property: scale;
          to: 1.3 1.3 1.3;
          dur: 150;
          startEvents: mouseenter"
        animation__restore="
          property: scale;
          to: 1 1 1;
          dur: 150;
          startEvents: mouseleave"
        event-set__click="
          _event: click;
          color: #1D9E75">
      </a-sphere>

      <!-- Cilindro -->
      <a-cylinder
        position="2 1 -4"
        radius="0.4"
        height="2"
        color="#4CC3D9"
        animation__hover="
          property: scale;
          to: 1.3 1.3 1.3;
          dur: 150;
          startEvents: mouseenter"
        animation__restore="
          property: scale;
          to: 1 1 1;
          dur: 150;
          startEvents: mouseleave"
        event-set__click="
          _event: click;
          color: #E24B4A">
      </a-cylinder>

      <a-plane
        position="0 0 0"
        rotation="-90 0 0"
        width="20"
        height="20"
        color="#3a3a4a">
      </a-plane>

      <a-sky color="#1a1a2e"></a-sky>

    </a-scene>

  </body>
</html>
